<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Propiedades de position</title>
    <style>
        * { box-sizing: border-box;}
        body {
            margin: 1rem;
            font-size: 2rem;
            font-family: sans-serif;
            background-color: black;
            height: 500vh;
        }
        h1 { 
            color: white;
            font-size: 2.5rem;
            text-align: center;
        }
        div { border-radius: 5px; background-color: gray;}
        .static {background-color: #ddd;}
        .relative {background-color: #81c476;}
        .absolute {background-color: #fc9191;}
        .fixed {background-color: #a8d5e2;}
        .sticky {background-color: #e1e1ac;}

        /* CSS Position*/
        .static { position: static;} 
        .relative { 
            position: relative;
            left: 50px;
            top: 5px;
            right: 20px;
        } 
        .absolute { 
            position: absolute;
            top:10px;
        } 
        .parent {
            position: relative;
        }
        .fixed { 
            position: fixed;
            top: 50%;
            z-index: 2;
        } 
        .sticky {
            position: sticky;
            top: 0px;
            z-index: 100;
        }

    </style>
</head>
<body>
    <h1>CSS Position - Propiedades</h1>
    <div class="parent">
        <div class="static">Static</div>
        <div class="relative">Relative</div>
        <div class="absolute">Absoulte</div>
        <div class="fixed">Fixed</div>
        <div class="sticky">Sticky</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="static">Static</div>
        <div class="relative">Relative</div>
        <div class="relative">Relative</div>
        <div class="relative">Relative</div>
        <div class="relative">Relative</div>
        

        

    </div>
</body>
</html>